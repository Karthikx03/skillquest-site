# ──────────────────────────────────────────────────────────
# SkillQuest — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────

# PostgreSQL connection string (from Supabase, Railway, or Render)
# Example: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Secret used to sign JWTs — use a long random string in production
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=skillquest_dev_secret_change_me_in_production

# Admin dashboard credentials (for /admin.html login)
ADMIN_EMAIL=admin@skillquest.tw
ADMIN_PASSWORD=SkillQuest2026!

# Port the server listens on (Render / Railway set this automatically)
PORT=3000
